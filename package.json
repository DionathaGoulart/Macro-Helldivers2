{
  "name": "helldivers-macro",
  "productName": "Macro Helldivers 2",
  "description": "Ferramenta de macros otimizada para Helldivers 2",
  "author": "DionathaGoulart",
  "version": "0.2.1",
  "private": true,
  "main": "dist-electron/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.macro.helldivers",
    "productName": "Macro Helldivers 2",
    "files": [
      "dist",
      "dist-electron"
    ],
    "asarUnpack": [
      "**/@nut-tree-fork/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png",
      "requestedExecutionLevel": "requireAdministrator",
      "artifactName": "Macro-Helldivers-2-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "shortcutName": "Macro Helldivers 2"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DionathaGoulart",
        "repo": "Macro-Helldivers2"
      }
    ]
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "31.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}